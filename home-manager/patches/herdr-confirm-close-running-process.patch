+/// Narrow allowlist of interactive shells / shell-like wrappers used only by the
+/// pane-close confirmation predicate below. Deliberately does NOT reuse
+/// `is_generic_runtime_or_shell`, which includes node/python/bun — those are the
+/// exact runtimes AI agent CLIs run under, so treating them as "shell" would let
+/// an agent-running pane close without confirmation.
+fn is_shell_process_name(name: &str) -> bool {
+    let name = normalized_agent_lookup_name(path_basename(name));
+    matches!(
+        name.as_str(),
+        "sh" | "bash"
+            | "zsh"
+            | "fish"
+            | "nu"
+            | "dash"
+            | "ksh"
+            | "csh"
+            | "tcsh"
+            | "tmux"
+            | "cmd"
+            | "powershell"
+            | "pwsh"
+    )
+}
+
+/// Returns true when the foreground job contains a process that isn't the pane
+/// shell idling at its prompt.
+///
+/// Close confirmation uses this predicate. A member counts as "running" when
+/// either: it's a different PID than the pane's own shell PID (a shell script,
+/// nested shell, or program the shell launched — even if that member's own name
